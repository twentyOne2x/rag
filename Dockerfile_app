# syntax=docker/dockerfile:1.7

# Use a slimmer Python base image
FROM python:3.11-slim as base

# Set the working directory in the container
WORKDIR /app

# requirements first → better cache
COPY requirements.txt ./requirements.txt

RUN --mount=type=cache,target=/var/cache/apt \
    --mount=type=cache,target=/var/lib/apt \
    apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt

# 2· application code --------------------------------------------------
# Only copy the rag_v2 service source tree (and its configuration assets)
COPY src/rag_v2 /app/src/rag_v2
COPY configs/rag_v2 /app/configs/rag_v2

RUN echo "=== AFTER COPY ===" && ls -Rla /app

# 3· environment -------------------------------------------------------
ENV PYTHONPATH=/app/src
ENV UVICORN_HOST=0.0.0.0
ENV UVICORN_PORT=8080
ENV UVICORN_WORKERS=1

# Download NLTK data once at build time
RUN --mount=type=cache,target=/root/.cache/nltk \
    python -m nltk.downloader -d /usr/local/share/nltk_data stopwords punkt && \
    chmod -R a+r /usr/local/share/nltk_data
ENV NLTK_DATA=/usr/local/share/nltk_data


EXPOSE 8080

# 4· entrypoint --------------------------------------------------------
CMD ["uvicorn", "src.rag_v2.app:app", "--host", "${UVICORN_HOST:-0.0.0.0}", "--port", "${UVICORN_PORT:-8080}", "--workers", "${UVICORN_WORKERS:-1}"]

# NOTE: Tune UVICORN_WORKERS based on available CPUs (e.g. 1 worker per vCPU).
